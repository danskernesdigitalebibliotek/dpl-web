{
  "name": "library-service",
  "version": "0.0.7",
  "private": true,
  "description": "WeDoBooks SDK wrapper",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "rm -rf dist && node build.mjs && tsc --emitDeclarationOnly",
    "build:watch": "rm -rf dist && node build.mjs --watch & tsc --emitDeclarationOnly --watch",
    "clean": "rm -rf dist",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "peerDependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@wedobooks/sdk": "latest",
    "esbuild": "^0.27.0",
    "esbuild-plugin-polyfill-node": "^0.3.0",
    "typescript": "^5.9.3"
  },
  "sideEffects": false
}
