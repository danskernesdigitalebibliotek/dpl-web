<a
  class="content-list-item content-list-item-grid arrow__hover--right-small" {{ attributes.addClass(classes).setAttribute('href', url) }}>
  <div class="content-list-item__image-container status-parent status-parent--media-container">
    {{ include('@novel/components/event-status.html.twig', {
      status: status,
      status_value: status_value,
    }, false) }}
    {{ include('@novel/components/media-container.html.twig'
      , {
        attributes: create_attribute(),
        media: image,
        has_media: image,
        placeholder_text: image_placeholder_text,
      }, false) }}
  </div>
  <div class="content-list-item__content">
    <div class="content-list-item__tag-container">
      {{ categories }}
    </div>

    <div class="content-list-item__content-top-container">
      <div class="content-list-item__content-top-container__inner">
        <h2 class="content-list-item__title">{{ title }}</h2>
        {% if description %}
          <div class="content-list-item__description">
            {{ description }}
          </div>
        {% endif %}
      </div>
      <div class="content-list-item__content-top-container__meta">
        {{ ticket_price }}
      </div>
    </div>

    <div class="content-list-item__content-bottom-container">
      {% if location %}
        <div class="content-list-item__content-bottom-container__item">
          {{ source(baseIconPath ~ '/collection/icon-pin.svg') }}

          {{ location }}
        </div>
      {% endif %}
      {% if publication_date %}
        <div class="content-list-item__content-bottom-container__item">
          <p class="content-list-item__date">{{ publication_date }}</p>
        </div>
      {% endif %}
      {% if date %}
        <div class="content-list-item__content-bottom-container__item">
          {{ source(baseIconPath ~ '/collection/icon-event.svg') }}

          <p class="content-list-item__date">{{ date }}</p>
        </div>
      {% endif %}
      {% if start_date or end_date %}

        <div class="content-list-item__content-bottom-container__item content-list-item__content-bottom-container__item--time">
          {{ source(baseIconPath ~ '/collection/icon-time.svg') }}

          <time class="content-list-item__time"
                datetime="{{ datetime_attribute }}">
            {{ start_date }}{% if end_date %} - {{ end_date }}{% endif %}
          </time>
        </div>
      {% endif %}

    </div>

    {% if ticket_price %}
      <div class="content-list-item__content__price">
        {{ ticket_price }}
      </div>
    {% endif %}
  </div>
  {{ source(baseIconPath ~ '/arrow-ui/icon-arrow-ui-small-right.svg') }}
</a>
