{# Cache logic that we duplicate from the parent template
   cms/web/modules/contrib/facets/templates/facets-item-list.html.twig #}
{% if cache_hash %}
  <!-- facets cacheable metadata
    hash: {{ cache_hash }}
  {% if cache_contexts %}
    contexts: {{ cache_contexts }}
  {%- endif %}
  {% if cache_tags %}
    tags: {{ cache_tags }}
  {%- endif %}
  {% if cache_max_age %}
    max age: {{ cache_max_age }}
  {%- endif %}
  -->
{%- endif %}

<label class="input-label" id="facet_{{ facet.id }}_label">{{ facet.label }}</label>
<div class="facets-widget-{{ facet.widget.type }}">
  {% if items %}
    {%- set attributes = attributes.addClass('item-list__' ~ facet.widget.type) %}
    <{{ list_type }}{{ attributes }}>
      {%- for item in items -%}
        <li{{ item.attributes }}>{{ item.value }}</li>
      {%- endfor -%}
    </{{ list_type }}>
  {% endif %}
</div>
