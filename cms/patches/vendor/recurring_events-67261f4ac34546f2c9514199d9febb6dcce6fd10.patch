+   *  Whether we want to exclude dates that already exist.
+   *
+   * @return array
+   */
+  public function getEventDatesToCreate(EventSeries $event, bool $exclude_existing = FALSE) {
+    $form_data = $this->convertEntityConfigToArray($event);
+    $dates_to_create = [];
+
+    if (empty($form_data['type'])) {
+      return $dates_to_create;
+    }
+
+    if ($form_data['type'] === 'custom' && !empty($form_data['custom_dates'])) {
+      foreach ($form_data['custom_dates'] as $date_range) {
+        $dates_to_create[$date_range['start_date']->format('U') . ':' . $date_range['end_date']->format('U')] = [
+          'start_date' => $date_range['start_date'],
+          'end_date' => $date_range['end_date'],
+        ];
+      }
+    }
+    else {
+      $field_definition = $this->fieldTypePluginManager->getDefinition($form_data['type']);
+      $field_class = $field_definition['class'];
+      $dates_to_create = $field_class::calculateInstances($form_data);
+    }
+
+    if ($exclude_existing) {
+      /** @var EventInstance[] $existing_instances */
+      $existing_instances = $this->entityTypeManager->getStorage('eventinstance')->loadByProperties([
+        'eventseries_id' => $event->id(),
+      ]);
+
+      foreach ($existing_instances as $instance) {
+        $date_id = $this->getInstanceDateId($instance);
+
+        // Don't re-create instance with the same date ID.
+        if (array_key_exists($date_id, $dates_to_create)) {
+          unset($dates_to_create[$date_id]);
+        }
+      }
+    }
+
+    return $dates_to_create;
+  }
+
+  /**
+   * Generating an date ID, based on an instance.
+   *
+   * The ID will be a mix of the start and end dates, and will allow us to
+   * look up if a date combination already exists when we create instances.
+   */
+  public function getInstanceDateId(EventInstance $instance) {
+    try {
+      /** @var DateRangeItem $date */
+      $date = $instance->get('date')->first();
+
+      $properties = $date->getProperties();
+
+      /** @var DrupalDateTime $start */
+      $start = $properties['value']->getDateTime();
+      /** @var DrupalDateTime $end */
+      $end = $properties['end_value']->getDateTime();
+
+      return "{$start->format('U')}:{$end->format('U')}";
+    }
+    catch (\Exception $e) {
+      $this->loggerChannel->error('Could not create Date ID for event instance.');
+      $this->loggerChannel->error($e->getMessage());
+    }
+
+    return NULL;
+  }
