+   *   The entity type ID.
+   *
+   * @return mixed
+   *   The after_clone setting value.
+   */
+  public function getAfterCloneSetting($entity_type_id, $setting_name) {
+    $form_settings_after_clone = $this->config->get('form_settings_after_clone');
