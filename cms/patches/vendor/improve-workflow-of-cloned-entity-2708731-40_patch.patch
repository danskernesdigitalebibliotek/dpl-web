@@ -308,4 +308,42 @@
     $this->assertTrue($node->getTranslation('en')->isDefaultTranslation());
   }
 
+  /**
+   * Tests the redirection setting after doing entity clone.
+   */
+  public function testContentEntityCloneRedirect() {
+    $config = \Drupal::service('config.factory')->getEditable('entity_clone.settings');
+    $config->set('form_settings_after_clone', [
+      'node' => [
+        'redirect_to' => 'edit-form',
+      ],
+    ]);
+    $config->set('form_settings', [
+      'node' => [
+        'default_value' => 1,
+        'disable' => 0,
+        'hidden' => 0,
+      ],
+    ]);
+    $config->save();
+    $node_title = $this->randomMachineName(8);
+    $node = Node::create([
+      'type' => 'page',
+      'title' => $node_title,
+    ]);
+    $node->save();
+
+    $this->drupalGet("entity_clone/node/{$node->id()}");
+    $this->submitForm([], t('Clone'));
+
+    $nodes = \Drupal::entityTypeManager()
+      ->getStorage('node')
+      ->loadByProperties([
+        'title' => $node_title . ' - Cloned',
+      ]);
+    $node = reset($nodes);
+    $this->assertInstanceOf(Node::class, $node, 'Test node cloned found in database.');
+    $this->assertSession()->addressEquals("node/{$node->id()}/edit");
+  }
+
 }
