{
  "compilerOptions": {
    "lib": ["es2022", "dom"],
    "types": ["node"],
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "target": "es6",
    "skipLibCheck": true,
    "jsx": "react-jsx"
  },
  "include": ["**/src/**/*.ts", "**/src/**/*.tsx"],
  "exclude": ["node_modules"]
}
