{
  "compilerOptions": {
    "lib": ["es2022"],
    "types": ["node"],
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "target": "es6",
    "skipLibCheck": true
  },
  "include": ["**/src/**/*.ts"],
  "exclude": ["node_modules"]
}
