# Mark vendored contracts as generated so PRs collapse them.
# See https://docs.github.com/en/repositories/working-with-files/managing-files/customizing-how-changed-files-appear-on-github

openapi/*.yaml    linguist-generated=true
graphql/*.graphql linguist-generated=true

# The adapter is hand-edited.
openapi/publizon-adapter.yaml  linguist-generated=false
